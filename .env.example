# Copy this file to .env and fill in your values
# cp .env.example .env

# Required for AI generation and analysis
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your_deployment_name

# Optional - default used by Azure OpenAI client
AZURE_OPENAI_API_VERSION=2024-10-21

# Optional - only needed for AWS cloud runs
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=eu-west-1

# Optional - path to JMeter binary (default: jmeter, assumes it's on PATH)
JMETER_PATH=/opt/apache-jmeter/bin/jmeter
